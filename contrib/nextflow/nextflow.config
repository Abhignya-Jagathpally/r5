/*
================================================================================
Nextflow Configuration for MM Imaging Radiomics Pipeline
================================================================================

Profiles:
- local: Single machine execution
- slurm: HPC cluster with SLURM
- cloud: AWS/GCP cloud execution

Container support: Docker/Singularity
================================================================================
*/

manifest {
    name = 'MM Imaging Radiomics Pipeline'
    description = 'Multiple Myeloma imaging pathology and radiomics analysis'
    author = 'PhD Researcher 6'
    version = '0.1.0'
    nextflowVersion = '>=22.10.0'
}

// Default parameters
params {
    // Input/output
    data_dir = './data'
    output_dir = './results'

    // Model configuration
    embedding_backbone = 'uni'
    embedding_batch_size = 32
    num_epochs = 50
    learning_rate = 1e-4
    batch_size = 32

    // Model types
    baseline_models = ['abmil', 'clam', 'transmil']
    foundation_models = ['uni', 'gigapath']

    // Processing
    tile_size = 256
    tile_overlap = 0
    stain_norm_method = 'macenko'
    dedup_threshold = 0.95

    // Data splits
    train_ratio = 0.7
    val_ratio = 0.15
    test_ratio = 0.15
    stratify_by = 'outcome'
    seed = 42

    // Pipeline stages
    stages {
        tiling = true
        stain_norm = true
        dedup = true
        embeddings = true
        radiomics = true
        training = true
        evaluation = true
        report = true
    }

    // Experiment tracking
    tracking {
        backend = 'mlflow'
        experiment_name = 'mm_pipeline'
    }

    // Number of samples for testing
    num_samples = 0  // 0 = use all samples
}

// Define profiles
profiles {
    // Local execution
    local {
        process {
            executor = 'local'
            cpus = { check_max(2, 'cpus') }
            memory = { check_max(4.GB, 'memory') }
            time = { check_max(2.h, 'time') }

            withLabel: gpu {
                cpus = 4
                memory = 16.GB
                time = 12.h
            }

            withLabel: high_memory {
                cpus = 8
                memory = 32.GB
                time = 24.h
            }
        }

        executor {
            queueSize = 1
        }

        docker {
            enabled = false
        }
    }

    // SLURM cluster execution
    slurm {
        process {
            executor = 'slurm'
            queue = 'gpu'
            clusterOptions = '--partition=gpu --gres=gpu:1'
            cpus = 8
            memory = 32.GB
            time = 12.h

            withLabel: gpu {
                cpus = 8
                memory = 40.GB
                time = 24.h
                clusterOptions = '--partition=gpu --gres=gpu:1 --cpus-per-task=8 --mem=40G'
            }

            withLabel: high_memory {
                cpus = 16
                memory = 64.GB
                time = 24.h
                clusterOptions = '--partition=gpu --gres=gpu:2 --cpus-per-task=16 --mem=64G'
            }
        }

        executor {
            queueSize = 20
            submitRateLimit = '10 sec'
            pollInterval = '30 sec'
        }

        singularity {
            enabled = true
            autoMounts = true
            cacheDir = '/tmp/singularity'
        }
    }

    // AWS Batch profile — NOT configured.
    // To use: replace placeholders with your actual AWS settings.
    awsbatch {
        process {
            executor = 'awsbatch'
            queue = '<YOUR-AWS-BATCH-QUEUE>'  // e.g., 'gpu-queue'
            cpus = 8
            memory = 32.GB

            withLabel: gpu {
                cpus = 8
                memory = 40.GB
                container = '<YOUR-ECR-IMAGE-URI>'  // e.g., '123456789.dkr.ecr.us-east-1.amazonaws.com/mm-pipeline:latest'
            }
        }

        executor {
            awsregion = '<YOUR-AWS-REGION>'  // e.g., 'us-east-1'
            awscli = '/usr/local/aws-cli/v2/current/bin/aws'
        }

        docker {
            enabled = true
            runOptions = '-v /tmp:/tmp'
        }
    }

    // Google Cloud profile — NOT configured.
    // To use: replace placeholders with your actual GCP settings.
    gcloud {
        process {
            executor = 'google-batch'
            cpus = 8
            memory = 32.GB
            disk = '50 GB'

            withLabel: gpu {
                cpus = 8
                memory = 40.GB
                disk = '100 GB'
                machineType = 'n1-standard-8'
                gpuType = 'nvidia-tesla-v100'
                gpuNumber = 1
            }
        }

        google {
            project = '<YOUR-GCP-PROJECT>'  // e.g., 'my-research-project'
            zone = '<YOUR-GCP-ZONE>'  // e.g., 'us-central1-a'
            network = 'default'
            subnetwork = 'default'
            preemptible = true
        }

        docker {
            enabled = true
            registry = 'gcr.io'
        }
    }

    // Testing profile with reduced resources
    test {
        params {
            num_samples = 2
        }

        process {
            executor = 'local'
            cpus = 2
            memory = 4.GB
            time = 30.m

            withLabel: gpu {
                cpus = 2
                memory = 8.GB
                time = 1.h
            }
        }

        docker {
            enabled = true
        }
    }
}

// Container configuration
docker {
    enabled = false
    registry = 'docker.io'
    runOptions = '--gpus all -v /tmp:/tmp'
}

singularity {
    enabled = false
    autoMounts = true
    cacheDir = '.singularity'
}

// Conda configuration
conda {
    enabled = true
    cacheDir = '.conda'
    useMicromamba = true
}

// Resource limits
params {
    max_cpus = 32
    max_memory = 256.GB
    max_time = 120.h
}

def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) {
            println "   ERROR: invalid max_memory: ${params.max_memory}, using default 256 GB"
            return 256.GB
        }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) {
            println "   ERROR: invalid max_time: ${params.max_time}, using default 120 h"
            return 120.h
        }
    } else if (type == 'cpus') {
        try {
            return Math.min(obj, params.max_cpus as int)
        } catch (all) {
            println "   ERROR: invalid max_cpus: ${params.max_cpus}, using default 32"
            return 32
        }
    }
}

// Timeline and reports
timeline {
    enabled = true
    file = "${params.output_dir}/nextflow_timeline.html"
}

report {
    enabled = true
    file = "${params.output_dir}/nextflow_report.html"
}

trace {
    enabled = true
    file = "${params.output_dir}/nextflow_trace.txt"
    fields = 'task_id,name,status,exit,submit,duration,realtime,cpus,memory'
}

dag {
    enabled = true
    file = "${params.output_dir}/nextflow_dag.html"
}
